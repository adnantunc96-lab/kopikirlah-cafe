<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<!-- SEO: meta_desc _data/site.json'dan gelir -->
<title id="page-title">Kopikirlah Cafe – Singaraja, Bali</title>
<meta name="description" id="page-meta-desc" content="">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<!-- Netlify Identity Widget (giriş yönlendirmesi için) -->
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<style>
:root {
  --gold: #B87A20;
  --gold-light: #E8C97A;
  --gold-pale: #FFF8EC;
  --dark: #1C1209;
  --text: #2E1F0F;
  --muted: #7A6655;
  --bg: #FDFAF5;
  --surface: #F5F0E8;
  --white: #FFFFFF;
  --green: #25D366;
  --radius: 12px;
  --radius-lg: 18px;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; overflow-x: hidden; }

.header { position: sticky; top: 0; z-index: 200; background: rgba(253,250,245,0.96); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(184,122,32,0.15); padding: 0 5%; height: 64px; display: flex; align-items: center; justify-content: space-between; }
.logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--dark); cursor: pointer; letter-spacing: 0.02em; }
.logo span { color: var(--gold); }
.nav { display: flex; gap: 8px; align-items: center; }
.nav-btn { font-size: 0.85rem; font-weight: 500; padding: 7px 16px; border-radius: 50px; border: 1px solid rgba(184,122,32,0.3); background: transparent; color: var(--muted); cursor: pointer; transition: all 0.2s; }
.nav-btn:hover, .nav-btn.active { background: var(--gold); border-color: var(--gold); color: #fff; }
.icon-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid rgba(184,122,32,0.25); background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; text-decoration: none; color: var(--muted); transition: all 0.2s; }
.icon-btn:hover { background: var(--gold-pale); color: var(--gold); border-color: var(--gold); }
.icon-btn svg { width: 17px; height: 17px; }
.page { display: none; }
.page.active { display: block; }
.hero { padding: 80px 5% 70px; text-align: center; background: linear-gradient(170deg,var(--dark) 0%,#3A2010 100%); position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%,rgba(184,122,32,0.2) 0%,transparent 65%); pointer-events: none; }
.hero-badge { display: inline-block; font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold-light); font-weight: 500; border: 1px solid rgba(232,201,122,0.35); padding: 5px 16px; border-radius: 50px; margin-bottom: 1.5rem; }
.hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.6rem,6vw,5rem); font-weight: 700; color: #fff; line-height: 1.15; margin-bottom: 1rem; }
.hero h1 em { color: var(--gold-light); font-style: normal; }
.hero p { font-size: 1rem; color: rgba(255,255,255,0.65); max-width: 480px; margin: 0 auto 2rem; line-height: 1.8; }
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.btn-primary { font-size: 0.9rem; font-weight: 500; padding: 12px 28px; border-radius: 50px; background: var(--gold); color: #fff; border: none; cursor: pointer; transition: all 0.25s; box-shadow: 0 4px 20px rgba(184,122,32,0.35); }
.btn-primary:hover { background: #9A6618; transform: translateY(-1px); }
.btn-outline { font-size: 0.9rem; font-weight: 500; padding: 12px 28px; border-radius: 50px; background: transparent; color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.3); cursor: pointer; transition: all 0.25s; }
.btn-outline:hover { background: rgba(255,255,255,0.08); }
.section { padding: 60px 5%; border-bottom: 1px solid rgba(184,122,32,0.1); }
.sec-label { font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 6px; }
.sec-title { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem,3vw,2.2rem); font-weight: 600; color: var(--dark); margin-bottom: 1rem; }
.sec-divider { width: 48px; height: 2px; background: var(--gold); border-radius: 2px; margin-bottom: 2rem; }
.featured-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(200px,1fr)); gap: 16px; }
.feat-card { background: var(--white); border: 1px solid rgba(184,122,32,0.12); border-radius: var(--radius-lg); padding: 1.4rem; transition: all 0.25s; }
.feat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(184,122,32,0.1); border-color: rgba(184,122,32,0.3); }
.feat-icon { font-size: 2rem; margin-bottom: 0.75rem; }
.feat-name { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600; margin-bottom: 4px; color: var(--dark); }
.feat-price { font-size: 0.88rem; color: var(--gold); font-weight: 500; margin-bottom: 8px; }
.feat-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
.tab-nav { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 2rem; }
.tab { font-size: 0.82rem; font-weight: 500; padding: 7px 16px; border-radius: 50px; border: 1px solid rgba(184,122,32,0.25); background: transparent; color: var(--muted); cursor: pointer; transition: all 0.2s; }
.tab:hover, .tab.active { background: var(--gold); border-color: var(--gold); color: #fff; }
.menu-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(290px,1fr)); gap: 16px; }
.menu-card { background: var(--white); border: 1px solid rgba(184,122,32,0.1); border-radius: var(--radius-lg); padding: 1.4rem; transition: all 0.25s; }
.menu-card:hover { border-color: rgba(184,122,32,0.3); box-shadow: 0 8px 30px rgba(0,0,0,0.06); }
.menu-card.hidden { display: none; }
.card-title { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600; color: var(--dark); margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(184,122,32,0.12); }
.price-hdr { display: grid; grid-template-columns: 1fr 68px 68px; font-size: 0.68rem; font-weight: 600; color: var(--gold); text-transform: uppercase; letter-spacing: 1.5px; padding-bottom: 6px; margin-bottom: 2px; border-bottom: 1px dashed rgba(184,122,32,0.2); }
.price-hdr span:not(:first-child) { text-align: center; }
.mrow { display: grid; grid-template-columns: 1fr 68px 68px; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(184,122,32,0.06); font-size: 0.88rem; gap: 4px; }
.mrow.s { grid-template-columns: 1fr auto; }
.mrow:last-child { border-bottom: none; }
.mrow-price { text-align: center; color: var(--gold); font-weight: 500; font-size: 0.82rem; }
.mrow-price.r { text-align: right; }
.info-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 14px; margin-bottom: 1.5rem; }
.info-card { background: var(--white); border: 1px solid rgba(184,122,32,0.12); border-radius: var(--radius); padding: 1.1rem; display: flex; align-items: flex-start; gap: 12px; }
.info-icon { width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0; background: var(--gold-pale); border: 1px solid rgba(184,122,32,0.2); display: flex; align-items: center; justify-content: center; font-size: 1rem; }
.info-text h4 { font-family: 'Playfair Display', serif; font-size: 0.88rem; font-weight: 600; color: var(--dark); margin-bottom: 4px; }
.info-text p { font-size: 0.83rem; color: var(--muted); line-height: 1.55; }
.info-text a { color: var(--gold); text-decoration: none; }
.maps-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--dark); color: #fff; padding: 12px 24px; border-radius: 50px; font-size: 0.88rem; font-weight: 500; text-decoration: none; transition: all 0.25s; border: none; cursor: pointer; }
.maps-btn:hover { background: var(--gold); transform: translateY(-1px); }
.maps-btn svg { width: 16px; height: 16px; }
.wa-section { padding: 60px 5%; background: var(--dark); position: relative; overflow: hidden; }
.wa-section::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg,transparent,var(--gold),transparent); }
.wa-card { max-width: 800px; margin: 0 auto; display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
.wa-icon-wrap { width: 72px; height: 72px; border-radius: 20px; flex-shrink: 0; background: var(--green); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(37,211,102,0.3); }
.wa-icon-wrap svg { width: 38px; height: 38px; fill: #fff; }
.wa-body { flex: 1; min-width: 200px; }
.wa-body h3 { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 600; color: #fff; margin-bottom: 6px; }
.wa-body p { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin-bottom: 4px; }
.wa-num { color: rgba(255,255,255,0.85) !important; font-weight: 500 !important; font-size: 0.9rem !important; margin-top: 4px; }
.wa-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.wa-badge { font-size: 0.72rem; font-weight: 600; padding: 4px 12px; border-radius: 50px; letter-spacing: 0.5px; }
.wa-badge.green { background: rgba(37,211,102,0.15); color: #4AE080; border: 1px solid rgba(37,211,102,0.25); }
.wa-badge.gold { background: rgba(184,122,32,0.2); color: var(--gold-light); border: 1px solid rgba(184,122,32,0.3); }
.wa-cta { display: inline-flex; align-items: center; gap: 10px; background: var(--green); color: #fff; padding: 13px 26px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; text-decoration: none; flex-shrink: 0; transition: all 0.25s; box-shadow: 0 6px 20px rgba(37,211,102,0.3); }
.wa-cta:hover { background: #1DB954; transform: translateY(-1px); }
.wa-cta svg { width: 20px; height: 20px; fill: #fff; }
.footer { background: var(--dark); color: rgba(255,255,255,0.5); text-align: center; padding: 2.5rem 5%; border-top: 1px solid rgba(184,122,32,0.15); }
.footer-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; color: var(--gold-light); margin-bottom: 6px; }
.footer-sub { font-size: 0.82rem; margin-bottom: 1rem; }
.footer-socials { display: flex; justify-content: center; gap: 14px; margin-bottom: 1rem; }
.footer-soc { display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.2s; }
.footer-soc:hover { color: var(--gold-light); }
.footer-soc svg { width: 13px; height: 13px; }
.footer-copy { font-size: 0.72rem; opacity: 0.4; }
@media(max-width:640px){
  .header{padding:0 4%;height:58px}.logo{font-size:1.15rem}.nav-btn{font-size:0.78rem;padding:6px 12px}.icon-btn{width:32px;height:32px}.icon-btn svg{width:15px;height:15px}
  .hero{padding:60px 4% 56px}.hero p{font-size:0.9rem}.hero-btns{flex-direction:column;align-items:center}.btn-primary,.btn-outline{width:100%;max-width:280px;text-align:center}
  .section{padding:44px 4%}.featured-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}.menu-grid{grid-template-columns:1fr}.info-grid{grid-template-columns:1fr}
  .wa-card{flex-direction:column;align-items:flex-start;gap:1.25rem}.wa-cta{width:100%;justify-content:center}.wa-section{padding:44px 4%}
  .tab{font-size:0.76rem;padding:6px 12px}.price-hdr{grid-template-columns:1fr 60px 60px;font-size:0.64rem}.mrow{grid-template-columns:1fr 60px 60px;font-size:0.83rem}
}
</style>
</head>
<body>

<!-- ─── HEADER ─────────────────────────────── -->
<header class="header">
  <!-- logo metni JS ile _data/site.json'dan gelir -->
  <div class="logo" id="site-logo" onclick="showPage('home')">Kopikirlah <span>Cafe</span></div>
  <nav class="nav">
    <button class="nav-btn" id="nav-menu" onclick="showPage('menu')">Menu</button>
    <button class="nav-btn" id="nav-lokasi" onclick="showPage('lokasi')">Lokasi</button>
    <!-- instagram_url ve tiktok_url _data/lokasi.json'dan gelir -->
    <a href="#" id="ig-link" target="_blank" class="icon-btn" title="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
    </a>
    <a href="#" id="tt-link" target="_blank" class="icon-btn" title="TikTok">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
    </a>
  </nav>
</header>

<!-- ═══ HOME PAGE ═══════════════════════════ -->
<div class="page active" id="page-home">
  <div class="hero">
    <!-- ▼ CMS'den gelen alanlar: hero_badge, hero_title, hero_subtitle, hero_btn1, hero_btn2 -->
    <div class="hero-badge" id="hero-badge">✦ Singaraja, Bali ✦</div>
    <h1 id="hero-title">Kopikirlah<br><em>Cafe</em></h1>
    <p id="hero-subtitle">Di jantung kota Singaraja, tempat kopi terbaik bertemu suasana modern.</p>
    <div class="hero-btns">
      <button class="btn-primary" id="hero-btn1" onclick="showPage('menu')">Lihat Menu Lengkap</button>
      <button class="btn-outline" id="hero-btn2" onclick="showPage('lokasi')">Lokasi Kami</button>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">Paling disukai</div>
    <div class="sec-title">Menu Unggulan</div>
    <div class="sec-divider"></div>
    <!-- ▼ Bu grid JS ile _menu/unggulan/*.json'dan dinamik oluşturulur -->
    <div class="featured-grid" id="featured-grid">
      <!-- Fallback: JS yüklenemezse statik içerik görünür -->
      <div class="feat-card"><div class="feat-icon">☕</div><div class="feat-name">Butterscotch Latte</div><div class="feat-price">Rp 17.000 / 20.000</div><div class="feat-desc">Latte dengan aroma karamel mentega dan vanila.</div></div>
      <div class="feat-card"><div class="feat-icon">🧋</div><div class="feat-name">Oreo Milk Shake</div><div class="feat-price">Rp 15.000</div><div class="feat-desc">Milkshake creamy dengan potongan Oreo renyah.</div></div>
      <div class="feat-card"><div class="feat-icon">🍽️</div><div class="feat-name">Nasi Goreng Seafood</div><div class="feat-price">Rp 15.000</div><div class="feat-desc">Seafood segar dengan bumbu rempah khas.</div></div>
      <div class="feat-card"><div class="feat-icon">🧇</div><div class="feat-name">Waffle Coklat Keju</div><div class="feat-price">Rp 17.500</div><div class="feat-desc">Waffle renyah, coklat leleh, dan keju.</div></div>
      <div class="feat-card"><div class="feat-icon">🍟</div><div class="feat-name">Mix Plater</div><div class="feat-price">Rp 25.000</div><div class="feat-desc">Kombinasi sausage, nugget, dan fries crispy.</div></div>
      <div class="feat-card"><div class="feat-icon">🥑</div><div class="feat-name">Alpokat Juice</div><div class="feat-price">Rp 9.000</div><div class="feat-desc">Jus alpokat segar, tekstur creamy alami.</div></div>
    </div>
  </div>

  <!-- WhatsApp Section (içerik JS ile dolar) -->
  <div class="wa-section" id="wa-home">
    <div class="wa-card">
      <div class="wa-icon-wrap">
        <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.057 23.492a.5.5 0 0 0 .625.599l5.806-1.525A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.645-.523-5.148-1.43l-.368-.223-3.812 1.001 1.018-3.714-.24-.382A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
      </div>
      <div class="wa-body">
        <h3 id="wa-title-home">Pesan Langsung via WhatsApp</h3>
        <p id="wa-desc-home">Kami menerima pesanan melalui WhatsApp setiap hari.</p>
        <p class="wa-num" id="wa-num-home">+62 813-8251-901</p>
        <div class="wa-badges">
          <span class="wa-badge green">✓ Gratis Ongkir</span>
          <span class="wa-badge green">✓ Pesan Mudah</span>
          <span class="wa-badge gold" id="wa-delivery-badge-home">✦ Kurye Gratis</span>
        </div>
      </div>
      <a href="#" id="wa-cta-home" target="_blank" class="wa-cta">
        <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.057 23.492a.5.5 0 0 0 .625.599l5.806-1.525A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.645-.523-5.148-1.43l-.368-.223-3.812 1.001 1.018-3.714-.24-.382A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        <span id="wa-btn-text-home">Chat WhatsApp</span>
      </a>
    </div>
  </div>

  <footer class="footer">
    <div class="footer-logo" id="footer-logo-home">Kopikirlah Cafe</div>
    <p class="footer-sub">Singaraja, Bali</p>
    <div class="footer-socials">
      <a href="#" id="footer-ig-home" target="_blank" class="footer-soc">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
        @kopikirlahcafe
      </a>
      <a href="#" id="footer-tt-home" target="_blank" class="footer-soc">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
        @kopikirlahcafe
      </a>
    </div>
    <p class="footer-copy">© 2024 Kopikirlah Cafe. Semua hak dilindungi.</p>
  </footer>
</div>

<!-- ═══ MENU PAGE ════════════════════════════ -->
<div class="page" id="page-menu">
  <div class="section">
    <div class="sec-label">Pilihan terbaik kami</div>
    <div class="sec-title">Menu Kami</div>
    <div class="sec-divider"></div>
    <div class="tab-nav">
      <button class="tab active" onclick="filter('all',this)">Semua menu</button>
      <button class="tab" onclick="filter('kopi',this)">☕ Kopi</button>
