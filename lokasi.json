<!-- ─── JAVASCRIPT ────────────────────────── -->
<script>
// ═══════════════════════════════════════════
// 1. SAYFA NAVİGASYONU
// ═══════════════════════════════════════════
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  if (name === 'menu')   document.getElementById('nav-menu').classList.add('active');
  if (name === 'lokasi') document.getElementById('nav-lokasi').classList.add('active');
  window.scrollTo(0, 0);
}

function filter(cat, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.menu-card').forEach(function(card) {
    card.classList.toggle('hidden', cat !== 'all' && card.dataset.cat !== cat);
  });
}

// ═══════════════════════════════════════════
// 2. CMS VERİLERİNİ YÜKLE
// _data/*.json dosyaları Decap CMS tarafından
// güncellenince bu fetch'ler en son veriyi çeker.
// ═══════════════════════════════════════════
async function loadCMSData() {
  try {
    // ── site.json ──────────────────────────
    const siteRes = await fetch('/_data/site.json');
    if (siteRes.ok) {
      const s = await siteRes.json();
      // Sayfa başlığı
      document.title = (s.site_title || 'Kopikirlah Cafe') + ' – Singaraja, Bali';
      document.getElementById('page-meta-desc').setAttribute('content', s.meta_desc || '');
      // Hero
      if (s.hero_badge)    document.getElementById('hero-badge').textContent    = s.hero_badge;
      if (s.hero_title)    document.getElementById('hero-title').innerHTML       = s.hero_title.replace(' ', '<br><em>') + '</em>';
      if (s.hero_subtitle) document.getElementById('hero-subtitle').textContent  = s.hero_subtitle;
      if (s.hero_btn1)     document.getElementById('hero-btn1').textContent      = s.hero_btn1;
      if (s.hero_btn2)     document.getElementById('hero-btn2').textContent      = s.hero_btn2;
      // Logo
      document.getElementById('site-logo').innerHTML = s.site_title
        ? s.site_title.replace(' ', ' <span>') + '</span>'
        : 'Kopikirlah <span>Cafe</span>';
      ['home','menu','lokasi'].forEach(p => {
        const el = document.getElementById('footer-logo-' + p);
        if (el) el.textContent = s.site_title || 'Kopikirlah Cafe';
      });
    }

    // ── whatsapp.json ──────────────────────
    const waRes = await fetch('/_data/whatsapp.json');
    if (waRes.ok) {
      const w = await waRes.json();
      const waUrl = 'https://wa.me/' + (w.wa_number || '628138251901');
      ['home', 'lokasi'].forEach(suffix => {
        const titleEl   = document.getElementById('wa-title-' + suffix);
        const descEl    = document.getElementById('wa-desc-' + suffix);
        const numEl     = document.getElementById('wa-num-' + suffix);
        const ctaEl     = document.getElementById('wa-cta-' + suffix);
        const btnTxtEl  = document.getElementById('wa-btn-text-' + suffix);
        const badgeEl   = document.getElementById('wa-delivery-badge-' + suffix);
        if (titleEl)  titleEl.textContent  = w.wa_title   || '';
        if (descEl)   descEl.textContent   = w.wa_desc    || '';
        if (numEl)    numEl.textContent    = w.wa_display || '';
        if (ctaEl)    ctaEl.href           = waUrl;
        if (btnTxtEl) btnTxtEl.textContent = w.wa_btn     || 'Chat WhatsApp';
        if (badgeEl)  badgeEl.style.display = w.show_free_delivery ? '' : 'none';
      });
    }

    // ── lokasi.json ────────────────────────
    const lokRes = await fetch('/_data/lokasi.json');
    if (lokRes.ok) {
      const l = await lokRes.json();
      // Header ikonları
      ['ig-link','footer-ig-home','footer-ig-menu','footer-ig-lokasi','lokasi-ig']
        .forEach(id => { const el=document.getElementById(id); if(el) el.href = l.instagram_url || '#'; });
      ['tt-link','footer-tt-home','footer-tt-menu','footer-tt-lokasi','lokasi-tt']
        .forEach(id => { const el=document.getElementById(id); if(el) el.href = l.tiktok_url || '#'; });
      // Lokasyon kartları
      const addrEl = document.getElementById('lokasi-address');
      if (addrEl) addrEl.innerHTML = (l.address1 || '') + '<br>' + (l.address2 || '');
      const ratingEl = document.getElementById('lokasi-rating');
      if (ratingEl) ratingEl.innerHTML = (l.rating || '') + '<br>"' + (l.rating_quote || '') + '"';
      const mapsEl = document.getElementById('maps-link');
      if (mapsEl) mapsEl.href = l.maps_url || '#';
    }

  } catch(e) {
    // JSON yüklenemezse statik fallback içerik görünür, hata gösterilmez
    console.warn('CMS data could not be loaded, using static fallback.', e);
  }
}

// ═══════════════════════════════════════════
// 3. NETLİFY IDENTİTY — Admin yönlendirme
// ═══════════════════════════════════════════
if (window.netlifyIdentity) {
  window.netlifyIdentity.on('init', user => {
    if (!user) {
      window.netlifyIdentity.on('login', () => {
        document.location.href = '/admin/';
      });
    }
  });
}

// Sayfa yüklenince CMS verilerini çek
document.addEventListener('DOMContentLoaded', loadCMSData);
</script>

